from PyQt5.QtWidgets import QMainWindow, QVBoxLayout, QWidget, QPushButton, QTableWidget

class MainWindowUI(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setup_ui()

    def setup_ui(self):
        self.setWindowTitle("Main Window")
        self.central_widget = QWidget()
        self.setCentralWidget(self.central_widget)

        self.layout = QVBoxLayout(self.central_widget)

        self.qt_all_signals = QTableWidget()
        self.layout.addWidget(self.qt_all_signals)

        self.btn_open_files = QPushButton('Open files')
        self.layout.addWidget(self.btn_open_files)

class MainWindow(MainWindowUI):
    def __init__(self, version: str):
        super().__init__()
        self.setWindowTitle(version)
        self.btn_open_files.clicked.connect(self.insert_all_signals)

